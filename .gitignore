# NOTE: gitignore does NOT support trailing comments on pattern lines — a
# trailing comment silently breaks the pattern (that bug once let the
# decompiled dirs and DVPET_SOURCE.md slip into the public repo). Keep every
# comment on its own line.

# Python
.venv/
# deploy.sh's on-demand twine venv
.release-venv/
# check.sh dev-tools venv
.venv-dev/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# Raw DVPet jar dump — NOT needed once data/assets are vendored (below). Kept out of the repo.
_extract/
raw_resources
raw_model

# Game data + assets are now VENDORED in src/tuipet/data/ (CSVs, sprite/effect/icon/
# background/egg atlases, sounds) so the DVPet jar is no longer needed to build or run
# tuipet. Regeneration via tools/setup_assets.sh is still possible if the jar is present.

# Save data
*.save

# Decompiled DVPet Java used only for the porting audit — never commit (copyrighted).
# _audit_src is PARTIAL (View only; Model/Controller stubs, from /tmp/view.jar);
# _decompiled is COMPLETE (full app jar: Model + Controller + View), the canonical reference.
_audit_src/
_decompiled/

# Third-party fan-project checkouts kept only as local reference material
corpus/

# decompilation-derived analysis notes -- keep local, not in the public repo
ANIMATION_AUDIT.md
DNA_SCOPE.md
SHOP_ITEMS.md
POOP_POSTMORTEM.md
# decompiled-source audit doc — never commit (copyrighted)
DVPET_SOURCE.md
# clone-era code-comparison doc — keep local
TRAINING_COMPARISON.md

server/lobby_feed.jsonl*
